# Configuración de Email - Copiar a .env y completar con tus datos

# === CONFIGURACIÓN SMTP ===
# Para Gmail:
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Para Outlook/Hotmail:
# SMTP_SERVER=smtp-mail.outlook.com
# SMTP_PORT=587

# === CREDENCIALES ===
# IMPORTANTE: Si usas Gmail, debes crear una "Contraseña de aplicación"
# Tutorial: https://support.google.com/accounts/answer/185833
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_contraseña_de_aplicacion

# Nombre que aparecerá como remitente
EMAIL_FROM_NAME=Nuevas Energías

# === GITHUB PAGES ===
# URL base de tu repositorio de GitHub Pages
# Formato: https://usuario.github.io/nombre-repo
GITHUB_PAGES_BASE=https://administracion-ne.github.io/informes-fv/
