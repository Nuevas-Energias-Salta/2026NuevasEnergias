# Variables de entorno para Notion ERP
# Copia este archivo a .env y completa con tus valores

# Token de Notion API (obtener de https://www.notion.so/my-integrations)
NOTION_TOKEN=tu_notion_token_aqui

# Trello API Key (obtener de https://trello.com/app-key)
TRELLO_API_KEY=f529e10ec3bac9427b5c1abcfa2ec821

# Trello Token (generar en https://trello.com/1/connect?name=NotionERP&response_type=token&key=TU_API_KEY)
TRELLO_TOKEN=tu_trello_token_aqui

# Opcional: IDs personalizados (si cambias las bases de datos)
# NOTION_PAGE_ID=tu_page_id
# CENTROS_DB_ID=tu_centros_db_id
# CLIENTES_DB_ID=tu_clientes_db_id
# PROVEEDORES_DB_ID=tu_proveedores_db_id
