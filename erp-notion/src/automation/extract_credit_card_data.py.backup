import pdfplumber
import re
import json
import os
import sys
import io
from datetime import datetime

# Fix for Windows console encoding
sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding='utf-8')

def detect_bank(text):
    """Detecta el banco basado en palabras clave en el texto del PDF"""
    # Debug
    # print(f"DEBUG TEXT: {text[:200]}")
    
    # BBVA a veces tiene texto invertido "AVBB" o explícito "BBVA"
    # Priorizar BBVA si aparece
    if "BBVA" in text.upper() or "AVBB" in text.upper() or "BANCO BBVA" in text.upper():
        return "BBVA"
        
    # Galicia
    if "GALICIA" in text.upper() or "BANCO GALICIA" in text.upper():
        return "GALICIA"
        
    # Fallback por tipo de tarjeta si es muy obvio, pero cuidado con falsos positivos
    if "VISA BUSINESS" in text.upper():
        # Podría ser cualquiera, pero si no dijo BBVA antes, asumimos Galicia por defecto
        # o devolvemos desconocido para no romper el parser equivocado.
        # En el caso de "Statements (4).pdf", dice "Visa" pero es BBVA.
        return "GALICIA" 

    return "DESCONOCIDO"

def parse_galicia(pdf):
    """
    Parsea resumen de Galicia Visa Business
    SOLO extrae de la sección DETALLE DEL CONSUMO
    """
    movements = []
    
    print("   -> Procesando formato GALICIA...")
    print("   -> Extrayendo SOLO de sección 'DETALLE DEL CONSUMO'...")
    
    for page in pdf.pages:
        text = page.extract_text()
        if not text: continue
        
        lines = text.split('\n')
        
        # Detectar inicio y fin de sección "DETALLE DEL CONSUMO"
        in_detalle_section = False
        
        for line in lines:
            # Detectar inicio de sección
            if "DETALLE DEL CONSUMO" in line.upper():
                in_detalle_section = True
                print(f"   -> Encontrada sección DETALLE DEL CONSUMO")
                continue
            
            # Detectar fin de sección (línea de totales o nueva sección)
            if in_detalle_section and any(marker in line.upper() for marker in [
                "TOTAL CONSUMOS", "TOTAL A PAGAR", "TARJETA", "COMISIÓN MANT",
                "Cuotas a vencer"
            ]):
                print(f"   -> Fin de sección DETALLE DEL CONSUMO")
                in_detalle_section = False
                continue
            
            # Si estamos en la sección, procesar líneas de consumo
            if not in_detalle_section:
                continue
            
            # Ignorar línea de encabezado de columnas
            if "FECHA" in line and "REFERENCIA" in line:
                continue
            
            # Buscar líneas que empiezan con fecha DD-MM-YY
            match = re.search(r'^(\d{2}-\d{2}-\d{2})\s+(.+)$', line)
                for token in tokens:
                    # Detener si encontramos un monto
                    if re.match(r'^\d{1,3}(?:\.\d{3})*,\d{2}$', token):
                        break
                    # Ignorar tokens que parezcan comprobantes (6+ dígitos)
                    if re.match(r'^\d{6,}$', token):
                        continue
                    # Ignorar tokens con formato de número interno (000123)
                    if re.match(r'^0+\d+$', token):
                        continue
                    # Ignorar tokens muy cortos que parecen códigos
                    if len(token) <= 2 and token.replace('-', '').replace('.', '').isdigit():
                        continue
                    clean_tokens.append(token)
                
                desc = " ".join(clean_tokens).strip()
                
                # Limpieza final: remover números de factura largos y patrones específicos
                desc = re.sub(r'\d{10,}', '', desc)  # Quitar números muy largos
                desc = re.sub(r'\d{6}-\d{3}-\d{3}', '', desc)  # Patrones como 123456-789-012
                desc = re.sub(r'\s+', ' ', desc)  # Múltiples espacios a uno solo
                
                if not desc or len(desc) < 3:
                    continue
                
                movements.append({
                    "fecha": fecha_str,
                    "descripcion": desc,
                    "monto": monto_val,
                    "moneda": moneda,
                    "banco": "GALICIA",
                    "original": line
                })

    return movements

def parse_bbva(pdf, period_start=None, period_end=None):
    """Parsea resumen BBVA con filtrado por período"""
    movements = []
    
    # Primero: extraer todas las fechas para detectar el período
    all_dates = []
    meses = {
        "Ene": "01", "Feb": "02", "Mar": "03", "Abr": "04", "May": "05", "Jun": "06",
        "Jul": "07", "Ago": "08", "Sep": "09", "Oct": "10", "Nov": "11", "Dic": "12"
    }
    
    for page in pdf.pages:
        text = page.extract_text()
        if text:
            lines = text.split('\n')
            for line in lines:
                # Patrón BBVA: DD-MMM-YY (ej: 06-Ago-25)
                match = re.search(r'^(\d{2})-([A-Za-z]{3})-(\d{2})', line)
                if match:
                    dd = match.group(1)
                    mm_str = match.group(2)
                    yy = match.group(3)
                    mm = meses.get(mm_str.title(), "00")
                    fecha_fmt = f"{dd}-{mm}-{yy}"
                    all_dates.append(fecha_fmt)
    
    # Detectar período si no se proporcionó
    if not period_start or not period_end:
        period_start, period_end = detect_billing_period(all_dates)
        if period_start and period_end:
            print(f"   -> Período detectado: {period_start.strftime('%d-%m-%Y')} a {period_end.strftime('%d-%m-%Y')}")
        else:
            print("   -> ⚠️  No se pudo detectar el período de facturación")
    
    print("   -> Procesando formato BBVA...")
    print(f"   -> Filtrando por período y montos en ARS...")
    
    for page in pdf.pages:
        text = page.extract_text()
        if not text: continue
        
        lines = text.split('\n')
        for line in lines:
            # Patrón BBVA: DD-MMM-YY (ej: 06-Ago-25)
            match = re.search(r'^(\d{2})-([A-Za-z]{3})-(\d{2})\s+(.+)$', line)
            if match:
                dd = match.group(1)
                mm_str = match.group(2)
                yy = match.group(3)
                resto = match.group(4)
                
                mm = meses.get(mm_str.title(), "00")
                fecha_fmt = f"{dd}-{mm}-{yy}"
                
                # FILTRO 1: Verificar si está en período de facturación
                if period_start and period_end:
                    if not is_in_billing_period(fecha_fmt, period_start, period_end):
                        continue
                
                # FILTRO 2: Ignorar pagos, saldos y conceptos no consumos
                keywords_to_ignore = [
                    "SU PAGO EN", "SALDO ANTERIOR", "PAGO DE RESUMEN",
                    "COMISION", "SEGURO", "IMPUESTO", "PERCEP", "IVA", 
                    "INTERESES", "MANTENCION", "ANUAL", "DB.RG", "DB IVA"
                ]
                if any(k in line.upper() for k in keywords_to_ignore):
                    continue
                
                tokens = resto.split()
                if len(tokens) < 2: continue
                
                # Función para detectar montos argentinos
                def is_monto_ars(s):
                    return re.match(r'^\d{1,3}(?:\.\d{3})*,\d{2}$', s)
                
                # Buscar el último monto en formato argentino
                monto_val = None
                for i in range(len(tokens)-1, -1, -1):
                    token = tokens[i]
                    if is_monto_ars(token):
                        try:
                            monto_clean = token.replace('.', '').replace(',', '.')
                            monto_val = float(monto_clean)
                            break
                        except:
                            continue
                
                if monto_val is None:
                    continue
                
                # FILTRO 3: Rango de montos razonable
                if monto_val < 10 or monto_val > 5_000_000:
                    continue
                
                # FILTRO 4: Solo ARS (BBVA rara vez tiene USD en consumos)
                if "USD" in line.upper() or "U$S" in line.upper():
                    continue
                
                # Extraer descripción limpia
                desc_tokens = []
                for token in tokens:
                    # Detener si encontramos monto
                    if is_monto_ars(token):
                        break
                    # Ignorar comprobantes y cupones
                    if re.match(r'^\d{6,}$', token):
                        continue
                    # Ignorar referencias de cupón
                    if "C." in token:
                        continue
                    # Ignorar patrones de fechas futuras (ej: "06-Feb-26")
                    if re.match(r'^\d{2}-[A-Za-z]{3}-\d{2}$', token):
                        continue
                    desc_tokens.append(token)
                
                desc = " ".join(desc_tokens).strip()
                
                # Limpieza adicional para BBVA
                desc = re.sub(r'\d{6,}', '', desc)  # Quitar números largos
                desc = re.sub(r'\d{3}-\d{4}-\d{3}', '', desc)  # Patrones de factura
                desc = re.sub(r'\s+', ' ', desc)  # Múltiples espacios
                
                if not desc or len(desc) < 3:
                    continue
                
                movements.append({
                    "fecha": fecha_fmt,
                    "descripcion": desc,
                    "monto": monto_val,
                    "moneda": "ARS",
                    "banco": "BBVA",
                    "original": line
                })

    return movements

def detect_billing_period(dates):
    """Detecta el período de facturación basado en las fechas encontradas"""
    if not dates:
        return None, None
    
    # Convertir fechas a objetos datetime
    valid_dates = []
    for date_str in dates:
        try:
            day, month, year = map(int, date_str.split('-'))
            # Ajustar año (asumir 2000s)
            year = 2000 + year
            valid_dates.append((date_str, datetime(year, month, day)))
        except:
            continue
    
    if not valid_dates:
        return None, None
    
    # Ordenar por fecha
    valid_dates.sort(key=lambda x: x[1])
    
    # La fecha más reciente probablemente indica el fin del período
    latest_date = valid_dates[-1][1]
    
    # Estimar período: aproximadamente 30 días antes de la fecha más reciente
    period_start = latest_date.replace(day=1)  # Primer día del mes
    if latest_date.day < 15:
        # Si es primera quincena, período es mes anterior
        if latest_date.month == 1:
            period_start = latest_date.replace(year=latest_date.year-1, month=12, day=1)
        else:
            period_start = latest_date.replace(month=latest_date.month-1, day=1)
    
    # El período termina aproximadamente 30 días después del inicio
    period_end = period_start
    if period_start.month == 12:
        period_end = period_start.replace(year=period_start.year+1, month=1, day=1)
        period_end = period_end.replace(day=min(period_start.day, 28))  # Ajustar por días del mes
    else:
        period_end = period_start.replace(month=period_start.month+1, day=min(period_start.day, 28))
    
    return period_start, period_end

def is_in_billing_period(date_str, period_start, period_end):
    """Verifica si una fecha está dentro del período de facturación"""
    try:
        day, month, year = map(int, date_str.split('-'))
        year = 2000 + year
        movement_date = datetime(year, month, day)
        
        # Permitir margen de 5 días antes y después del período
        margin_days = 5
        effective_start = period_start.replace(day=max(1, period_start.day - margin_days))
        effective_end = period_end.replace(day=min(28, period_end.day + margin_days))
        
        return effective_start <= movement_date <= effective_end
    except:
        return False

def is_historical_consumption(line, date_str):
    """Detecta si un consumo es histórico (no del período actual)"""
    # Patrones de consumos históricos que no deben procesarse
    historical_patterns = [
        # Fechas muy antiguas (más de 6 meses)
    ]
    
    try:
        day, month, year = map(int, date_str.split('-'))
        year = 2000 + year
        movement_date = datetime(year, month, day)
        current_date = datetime(2026, 1, 22)  # Fecha del resumen
        
        # Si el consumo es de más de 90 días antes de la fecha del resumen, es histórico
        days_diff = (current_date - movement_date).days
        if days_diff > 90:
            return True
            
        # Verificar patrones específicos en la línea
        historical_indicators = [
            "SALDO ANTERIOR", "RESUMEN ANTERIOR", "PERIODO ANTERIOR"
        ]
        
        for indicator in historical_indicators:
            if indicator in line.upper():
                return True
                
    except:
        pass
    
    return False

def main():
    folder = "resumenes"
    if not os.path.exists(folder):
        print(f"Carpeta {folder} no encontrada.")
        return

    files = [f for f in os.listdir(folder) if f.endswith(".pdf")]
    
    all_movements = []
    
    print(f"Encontrados {len(files)} archivos PDF.")
    
    for filename in files:
        path = os.path.join(folder, filename)
        print(f"\nProcesando: {filename}")
        
        try:
            with pdfplumber.open(path) as pdf:
                # Detectar banco usando primera pagina
                first_text = pdf.pages[0].extract_text() if pdf.pages else ""
                if not first_text:
                    print("   ⚠️  Archivo sin texto (posible imagen/scan). Omitiendo.")
                    # AQUI PODRIAMOS AGREGAR LOGICA OCR SI TESSERACT ESTUVIERA INSTALADO
                    continue
                    
                bank = detect_bank(first_text)
                print(f"   🏦 Banco detectado: {bank}")
                
                movs = []
                if bank == "GALICIA":
                    movs = parse_galicia(pdf)
                elif bank == "BBVA":
                    movs = parse_bbva(pdf)
                else:
                    print("   ⚠️  Banco no soportado o no detectado.")
                
                print(f"   ✓ {len(movs)} movimientos extraídos.")
                all_movements.extend(movs)
                
        except Exception as e:
            print(f"   ❌ Error al procesar archivo: {e}")

    # Exportar resultados
    if all_movements:
        output_file = "extracted_movements.json"
        with open(output_file, 'w', encoding='utf-8') as f:
            json.dump(all_movements, f, indent=4, ensure_ascii=False)
        print(f"\n💾 Guardado en {output_file}")
        
        # Preview
        print("\n--- EJEMPLO DE DATOS EXTRAÍDOS ---")
        for m in all_movements[:5]:
            print(f"{m['fecha']} | {m['moneda']} {m['monto']:8.2f} | {m['descripcion']}")
    else:
        print("\nNo se extrajeron movimientos.")

if __name__ == "__main__":
    main()
