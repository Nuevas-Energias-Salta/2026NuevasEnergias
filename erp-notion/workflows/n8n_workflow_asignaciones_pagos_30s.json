            "id": "03e8527c-bea4-4057-9bc9-e897c1721d58",
            "name": "Get CxP Details",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                -800,
                112
            ]
        },
        {
            "parameters": {
                "jsCode": "// Recopilar todas las CxP y calcular asignaciones FIFO\nconst allCxP = $input.all();\n\n// Obtener datos del pago\nconst pagoId = $('Prep CxP Fetch').first().json.pagoId;\nconst montoTotalPago = $('Prep CxP Fetch').first().json.montoTotalPago;\nconst fechaPago = $('Prep CxP Fetch').first().json.fechaPago;\n\n// Obtener asignaciones existentes para este pago\nconst existingAsignaciones = $('Check Existing Asignaciones').first().json.results || [];\nconst cxpYaAsignadas = existingAsignaciones.map(a => \n  a.properties?.CxP?.relation?.[0]?.id\n).filter(id => id);\n\n// Calcular monto ya asignado\nconst montoYaAsignado = existingAsignaciones.reduce((sum, a) => \n  sum + (a.properties?.['Monto Asignado']?.number || 0), 0\n);\n\nlet montoRestante = montoTotalPago - montoYaAsignado;\nconst asignaciones = [];\n\n// Ordenar por fecha (FIFO)\nconst cxpOrdenadas = allCxP.map(item => {\n  const props = item.json.properties || {};\n  return {\n    id: item.json.id,\n    concepto: props['Factura n°']?.title?.[0]?.plain_text || 'Sin factura',\n    montoBase: props['Monto base']?.number || props['Monto']?.number || 0,\n    montoPagado: props['Monto Asignado Total']?.rollup?.number || props['Monto Pagado ']?.rollup?.number || 0,\n    fechaFactura: props['Fecha Factura']?.date?.start || '2000-01-01'\n  };\n}).sort((a, b) => a.fechaFactura.localeCompare(b.fechaFactura));\n\n// Distribuir el pago (FIFO) - solo para CxP que NO tienen asignación\nfor (const cxp of cxpOrdenadas) {\n  if (cxpYaAsignadas.includes(cxp.id)) continue;\n  \n  if (montoRestante <= 0) break;\n  \n  const saldoPendiente = cxp.montoBase - cxp.montoPagado;\n  if (saldoPendiente <= 0) continue;\n  \n  const montoAsignar = Math.min(montoRestante, saldoPendiente);\n  \n  asignaciones.push({\n    cxpId: cxp.id,\n    cxpConcepto: cxp.concepto,\n    montoAsignado: montoAsignar,\n    pagoId: pagoId,\n    fechaPago: fechaPago,\n    quedaPagada: (cxp.montoPagado + montoAsignar) >= cxp.montoBase,\n    saldoAFavor: 0,\n    montoTotalPago: montoTotalPago\n  });\n  \n  montoRestante -= montoAsignar;\n}\n\n// Si hay asignaciones, agregar el saldo a favor al último item\nif (asignaciones.length > 0) {\n  asignaciones[asignaciones.length - 1].saldoAFavor = montoRestante;\n} else {\n  // Si no hay asignaciones pero hay monto, todo es saldo a favor\n  return [{\n    pagoId: pagoId,\n    cxpId: null,\n    cxpConcepto: 'Sin asignación',\n    montoAsignado: 0,\n    fechaPago: fechaPago,\n    quedaPagada: false,\n    saldoAFavor: montoRestante,\n    montoTotalPago: montoTotalPago,\n    soloSaldoAFavor: true\n  }];\n}\n\nreturn asignaciones;"
            },
