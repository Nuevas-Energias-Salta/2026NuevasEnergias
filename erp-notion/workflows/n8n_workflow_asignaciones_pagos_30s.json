        {
            "parameters": {
                "jsCode": "const data = $input.item.json;\n\n// Obtener el pago vinculado a esta CxP (viene de la relación \"Pagos\")\nconst pagosRelation = data['Pagos'] || [];\n\n// Si no tiene pagos vinculados, no procesar\nif (pagosRelation.length === 0) {\n  return [];\n}\n\n// Devolver info para procesar cada pago vinculado\nreturn pagosRelation.map(pagoId => ({\n  pagoId: pagoId,\n  cxpId: data.id,\n  cxpConcepto: data['Concepto'] || 'Sin concepto'\n}));"
            },
