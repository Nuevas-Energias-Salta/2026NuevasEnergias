        {
            "parameters": {
                "jsCode": "// Preparar datos para obtener info de cada CxP\nlet prevData;\ntry {\n  prevData = $('Extract Pagos con CxP').first().json;\n} catch (e) {\n  prevData = $('Format Pago Data').first().json;\n}\n\nconst items = [];\n\nfor (const cxpId of prevData.cxpIds) {\n  items.push({\n    cxpId: cxpId,\n    pagoId: prevData.pagoId,\n    montoTotalPago: prevData.monto,\n    fechaPago: prevData.fechaPago,\n    conceptoPago: prevData.concepto\n  });\n}\n\nreturn items;"
            },
            "id": "741ea699-ab47-4613-9b28-de57c26c7364",
            "name": "Prep CxP Fetch",
