            "parameters": {
                "jsCode": "const data = $input.item.json;\n\n// Obtener datos directamente (el trigger ya los formatea)\nconst cxpRelation = data['Cuenta Por Pagar'] || [];\nconst monto = data['Monto'] || 0;\n\n// Solo procesar si tiene CxP vinculadas y monto > 0\nif (cxpRelation.length > 0 && monto > 0) {\n  return [{\n    pagoId: data.id,\n    monto: monto,\n    cxpIds: cxpRelation,\n    fechaPago: data['Fecha Pago'] || new Date().toISOString().split('T')[0],\n    concepto: data['Concepto'] || 'Pago'\n  }];\n}\n\nreturn [];"
            },
