        {
            "parameters": {
                "jsCode": "const pagoData = $input.item.json;\nconst prevItem = $('Code in JavaScript').first().json;\n\nconst props = pagoData.properties || {};\nconst cxpRelation = props['Cuenta Por Pagar']?.relation || [];\nconst monto = props['Monto']?.number || 0;\n\nif (monto > 0) {\n  return [{\n    pagoId: pagoData.id,\n    monto: monto,\n    cxpIds: cxpRelation.map(r => r.id),\n    fechaPago: props['Fecha Pago']?.date?.start || new Date().toISOString().split('T')[0],\n    concepto: props['Concepto']?.title?.[0]?.plain_text || 'Pago'\n  }];\n}\n\nreturn [];"
            },
