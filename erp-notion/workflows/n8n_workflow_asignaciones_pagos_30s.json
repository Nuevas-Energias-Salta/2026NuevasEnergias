            "name": "Format Pago Data"
        },
        {
            "parameters": {
                "jsCode": "// Agregar todos los items para encontrar el saldo a favor final\nconst allItems = $input.all();\n\n// Buscar el item que tiene el saldo a favor (es el último con asignación o el único si es soloSaldoAFavor)\nlet saldoAFavor = 0;\nlet pagoId = null;\nlet montoTotalPago = 0;\n\nfor (const item of allItems) {\n  if (item.json.saldoAFavor > 0) {\n    saldoAFavor = item.json.saldoAFavor;\n  }\n  pagoId = item.json.pagoId;\n  montoTotalPago = item.json.montoTotalPago || 0;\n}\n\n// Retornar un solo item con el saldo a favor\nreturn [{\n  pagoId: pagoId,\n  saldoAFavor: saldoAFavor,\n  montoTotalPago: montoTotalPago\n}];"
            },
