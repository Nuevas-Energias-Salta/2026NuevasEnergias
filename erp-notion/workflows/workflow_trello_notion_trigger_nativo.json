            "id": "get-cf-defs",
            "name": "Get Custom Fields",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                1050,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "// Extraer datos de la tarjeta\nconst tarjeta = $('Get Card Details').item.json;\nconst customFieldDefs = $input.all()[0].json;\n\n// Mapa de custom fields\nconst cfMap = {};\nif (Array.isArray(customFieldDefs)) {\n  for (const cf of customFieldDefs) {\n    cfMap[cf.id] = cf.name;\n  }\n}\n\nlet email = null;\nlet celular = null;\nlet monto = 0;\n\nfor (const cf of (tarjeta.customFieldItems || [])) {\n  const fieldName = cfMap[cf.idCustomField] || '';\n  const val = cf.value || {};\n  \n  if (fieldName.includes('Mail') && val.text) {\n    email = val.text;\n  }\n  if (fieldName.includes('Celular') && val.number) {\n    celular = val.number;\n  }\n  if (fieldName.toLowerCase().includes('monto') && val.number) {\n    monto = parseFloat(val.number);\n  }\n}\n\n// Extraer labels y determinar Centro de Costo\nconst labels = tarjeta.labels || [];\nlet ccSearchTerm = 'Varios';\n\nconst mapeoCC = {\n  'fv': 'Solar Fotovoltaico',\n  'solar': 'Solar Fotovoltaico',\n  'fotovoltaico': 'Solar Fotovoltaico',\n  'piletas': 'Climatización Piletas',\n  'climat': 'Climatización Piletas',\n  'climatizacion': 'Climatización Piletas',\n  'acs': 'ACS',\n  'agua caliente': 'ACS',\n  'biomasa': 'Biomasa',\n  'calefaccion': 'Calefacción Eléctrica',\n  'calefacción': 'Calefacción Eléctrica',\n  'pre': 'Calefacción Eléctrica',\n  'piso radiante': 'Calefacción Eléctrica',\n  'luminaria': 'Luminaria Solar',\n  'consultoria': 'Varios',\n  'consultoría': 'Varios',\n  'monitoreo': 'Varios',\n  'gestoria': 'Varios',\n  'gestoría': 'Varios',\n  'varios': 'Varios'\n};\n\nfor (const label of labels) {\n  const labelName = (label.name || '').toLowerCase();\n  for (const [key, value] of Object.entries(mapeoCC)) {\n    if (labelName.includes(key)) {\n      ccSearchTerm = value;\n      break;\n    }\n  }\n  if (ccSearchTerm !== 'Varios') break;\n}\n\nconst nombreCliente = tarjeta.name.split('-')[0].trim();\n\nreturn {\n  nombreTarjeta: tarjeta.name,\n  nombreCliente: nombreCliente,\n  email: email,\n  celular: celular,\n  monto: monto,\n  ccSearchTerm: ccSearchTerm\n};"
            },
