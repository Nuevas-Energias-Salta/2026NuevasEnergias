        {
            "parameters": {
                "jsCode": "const projectResult = $input.item.json;\nlet prevData = {};\n\ntry {\n  prevData = $('Prep Project (Existing Client)').item?.json || {};\n} catch (e) {\n  try {\n    prevData = $('Prep Project (New Client)').item?.json || {};\n  } catch (e2) {}\n}\n\nreturn {\n  projectId: projectResult.id,\n  nombreTarjeta: prevData.nombreTarjeta || 'Sin nombre',\n  monto: prevData.monto || 0,\n  ccId: prevData.ccId || null\n};"
