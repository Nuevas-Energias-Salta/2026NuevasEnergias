            "parameters": {
                "jsCode": "// Prep FIFO Data: combina datos del pago + CxP results + asignaciones existentes\n// Usa la referencia $('Normalizar Datos Pago') que a\u00fan funciona aqu\u00ed\nconst pagoData = $('Normalizar Datos Pago').item.json;\nconst existingData = $('Check Existing Asignaciones').item.json;\n\nreturn {\n  pagoId: pagoData.pagoId,\n  monto: pagoData.monto,\n  fechaPago: pagoData.fechaPago,\n  cxpResults: $input.item.json.results || [],\n  existingAsignaciones: existingData.results || []\n};"
            },
