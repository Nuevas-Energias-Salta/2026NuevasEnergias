            "parameters": {
                "jsCode": "// FIX: No referenciar $('Normalizar Datos Pago') desde aqui \u2014 el contexto ya no existe.\n// Leer pagoId y saldoAFavor DIRECTAMENTE de los items que llegan.\nconst allItems = $input.all();\nlet saldoFinal = 0;\nlet pagoId = null;\n\nfor (const it of allItems) {\n  // Tomar el primer pagoId que encontremos\n  if (!pagoId && it.json.pagoId) {\n    pagoId = it.json.pagoId;\n  }\n  // Tomar el saldo a favor m\u00e1s alto (es el del \u00faltimo item procesado)\n  if (it.json.saldoAFavor !== undefined && it.json.saldoAFavor > saldoFinal) {\n    saldoFinal = it.json.saldoAFavor;\n  }\n}\n\nif (!pagoId) {\n  console.log('ERROR: no se encontr\u00f3 pagoId en los items del merge');\n  return [];\n}\n\nconsole.log(`pagoId: ${pagoId} | saldoAFavor: ${saldoFinal}`);\nreturn [{ pagoId, saldoAFavor: saldoFinal }];"
