        {
            "parameters": {
                "jsCode": "// FIFO: asigna montos a CxP por orden de fecha.\n// FIX: pagoId y saldoAFavor ahora viajan en TODOS los items, no solo en el \u00faltimo.\n// NO usamos $('Normalizar Datos Pago') - leemos todo del input actual.\nconst inputData = $input.item.json;\nconst results = inputData.cxpResults || [];\nconst existingAsignaciones = inputData.existingAsignaciones || [];\n\nconst pagoId = inputData.pagoId;\nconst montoTotalPago = inputData.monto;\nconst fechaPago = inputData.fechaPago;\n\nif (!pagoId || montoTotalPago <= 0) {\n  return [{\n    error: 'Datos de pago incompletos',\n    soloSaldoAFavor: true\n  }];\n}\n\nconst cxpYaAsignadas = existingAsignaciones\n  .map(a => a.properties?.CxP?.relation?.[0]?.id)\n  .filter(id => id);\n\nconst montoYaAsignado = existingAsignaciones.reduce(\n  (sum, a) => sum + (a.properties?.['Monto Asignado']?.number || 0), 0\n);\n\nlet montoRestante = montoTotalPago - montoYaAsignado;\nconst asignaciones = [];\n\nconst cxpOrdenadas = results.map(page => {\n  const props = page.properties || {};\n  return {\n    id: page.id,\n    estado: props['Estado']?.select?.name || 'Pendiente',\n    concepto: props['Factura n\u00b0']?.title?.[0]?.plain_text || props['Concepto']?.title?.[0]?.plain_text || 'Sin factura',\n    montoBase: props['Monto base']?.number || props['Monto']?.number || 0,\n    montoPagado: props['Monto Asignado Total']?.rollup?.number || props['Monto Pagado ']?.rollup?.number || 0,\n    fechaFactura: props['Fecha Factura']?.date?.start || '2000-01-01'\n  };\n}).sort((a, b) => a.fechaFactura.localeCompare(b.fechaFactura));\n\nfor (const cxp of cxpOrdenadas) {\n  const saldoPendiente = cxp.montoBase - cxp.montoPagado;\n\n  if (saldoPendiente <= 0.01 && cxp.estado !== 'Pagado') {\n    asignaciones.push({\n      cxpId: cxp.id,\n      cxpConcepto: cxp.concepto,\n      montoAsignado: 0,\n      pagoId,\n      fechaPago,\n      quedaPagada: true,\n      saldoAFavor: 0,\n      montoTotalPago\n    });\n    continue;\n  }\n\n  if (cxpYaAsignadas.includes(cxp.id)) continue;\n  if (montoRestante <= 0.01) break;\n  if (saldoPendiente <= 0.01) continue;\n\n  const montoAsignado = Math.min(montoRestante, saldoPendiente);\n  const nuevoMontoPagado = cxp.montoPagado + montoAsignado;\n  asignaciones.push({\n    cxpId: cxp.id,\n    cxpConcepto: cxp.concepto,\n    montoAsignado: montoAsignado,\n    nuevoMontoPagado: nuevoMontoPagado,\n    pagoId,\n    fechaPago,\n    quedaPagada: (cxp.montoPagado + montoAsignado) >= (cxp.montoBase - 0.01),\n    saldoAFavor: 0,\n    montoTotalPago\n  });\n  montoRestante -= montoAsignar;\n}\n\nconst saldoFinal = Math.max(0, montoRestante);\n\nif (asignaciones.length > 0) {\n  // FIX: Poner saldoAFavor en TODOS los items\n  for (const asig of asignaciones) {\n    asig.saldoAFavor = saldoFinal;\n  }\n  return asignaciones;\n}\n\n// No hay CxP: todo es saldo a favor\nreturn [{\n  pagoId,\n  cxpId: null,\n  cxpConcepto: 'Sin asignaci\u00f3n',\n  montoAsignado: 0,\n  fechaPago,\n  quedaPagada: false,\n  saldoAFavor: saldoFinal,\n  montoTotalPago,\n  soloSaldoAFavor: true\n}];"
            },
