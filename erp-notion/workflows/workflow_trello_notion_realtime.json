                250,
                300
            ],
            "webhookId": "trello-sync"
        },
        {
            "parameters": {
                "jsCode": "// Validar que sea creación o actualización de tarjeta\nconst action = $input.item.json.body.action;\n\nif (!action || action.type !== 'createCard' && action.type !== 'updateCard') {\n  return null; // Ignorar otros eventos\n}\n\nconst tarjeta = action.data.card;\n\nreturn {\n  cardId: tarjeta.id,\n  cardName: tarjeta.name,\n  actionType: action.type\n};"
            },
            "id": "filter-event",
            "name": "Filter Card Events",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                450,
                300
            ]
        },
        {
            "parameters": {
                "url": "=https://api.trello.com/1/cards/{{ $json.cardId }}?key=f529e10ec3bac9427b5c1abcfa2ec821&token=ATTA4a2d8d0148cae05d395044b7779d80db44ae465d82aecdb32b0067daf008eeea7221D17C&customFieldItems=true",
                "options": {}
            },
            "id": "get-card-details",
            "name": "Get Card Details",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
