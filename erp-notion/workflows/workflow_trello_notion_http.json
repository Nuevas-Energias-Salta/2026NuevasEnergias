        {
            "parameters": {
                "jsCode": "// Preparar datos para CxC\nconst projectResult = $input.item.json;\nlet prevData = {};\n\ntry {\n  prevData = $('Pass Existing Client').item?.json || $('Update Client ID').item?.json || {};\n} catch(e) {\n  try {\n    prevData = $('Update Client ID').item?.json || {};\n  } catch(e2) {\n    prevData = $('Merge All Data').item?.json || {};\n  }\n}\n\nreturn {\n  projectId: projectResult.id,\n  nombreTarjeta: prevData.nombreTarjeta || projectResult.properties?.Nombre?.title?.[0]?.text?.content || 'Sin nombre',\n  monto: prevData.monto || 0,\n  ccId: prevData.ccId || null\n};"
            },
