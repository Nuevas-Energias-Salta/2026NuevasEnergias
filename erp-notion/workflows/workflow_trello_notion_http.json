        {
            "parameters": {
                "jsCode": "// Recopilar todos los datos\nconst extractData = $('Extract Data').item.json;\nconst ccResults = $('Find Centro de Costo').item.json.results || [];\nconst clientResults = $input.item.json.results || [];\n\nlet ccId = null;\nif (ccResults.length > 0) {\n  ccId = ccResults[0].id;\n}\n\nlet clientId = null;\nlet clientExists = false;\nif (clientResults.length > 0) {\n  clientId = clientResults[0].id;\n  clientExists = true;\n}\n\nreturn {\n  ...extractData,\n  ccId: ccId,\n  clientId: clientId,\n  clientExists: clientExists\n};"
            },
