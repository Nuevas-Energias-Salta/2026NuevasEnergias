                "jsonBody": "={\n  \"parent\": {\"database_id\": \"2e0c81c3-5804-8159-b677-fd8b76761e2f\"},\n  \"properties\": {\n    \"Nombre\": {\"title\": [{\"text\": {\"content\": \"{{ $json.nombreTarjeta }}\"}}]},\n    \"Estado\": {\"select\": {\"name\": \"Aprobado\"}},\n    \"Monto Contrato\": {\"number\": {{ $json.monto || 0 }}},\n    \"Cliente\": {\"relation\": [{{ $json.clientId ? '{\"id\": \"' + $json.clientId + '\"}' : '' }}]},\n    \"Centro de Costo\": {\"relation\": [{{ $json.ccId ? '{\"id\": \"' + $json.ccId + '\"}' : '' }}]}\n  }\n}"
