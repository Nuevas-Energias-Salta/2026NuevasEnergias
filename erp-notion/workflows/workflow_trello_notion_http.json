            "id": "get-cf-defs",
            "name": "Get Custom Fields Defs",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                650,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "// Extraer datos de la tarjeta\nconst tarjeta = $('Get Card Details').item.json;\n\n// Obtener todos los custom field definitions\nconst cfDefItems = $items('Get Custom Fields Defs');\nconst customFieldDefs = cfDefItems.map(item => item.json);\n\n// Mapa de custom fields: id -> name\nconst cfMap = {};\nfor (const cf of customFieldDefs) {\n  cfMap[cf.id] = cf.name;\n}\n\nlet email = null;\nlet celular = null;\nlet monto = 0;\n\nfor (const cf of (tarjeta.customFieldItems || [])) {\n  const fieldName = (cfMap[cf.idCustomField] || '').toLowerCase();\n  const val = cf.value || {};\n  \n  if (fieldName.includes('mail') && val.text) {\n    email = val.text;\n  }\n  if (fieldName.includes('celular') && (val.number || val.text)) {\n    celular = val.number || val.text;\n  }\n  if (fieldName.includes('monto') && val.number) {\n    monto = parseFloat(val.number);\n  }\n}\n\n// Extraer labels y determinar Centro de Costo\nconst labels = tarjeta.labels || [];\nlet ccSearchTerm = 'Varios';\n\nconst mapeoCC = {\n  'fv': 'Solar Fotovoltaico',\n  'solar': 'Solar Fotovoltaico',\n  'fotovoltaico': 'Solar Fotovoltaico',\n  'piletas': 'Climatización Piletas',\n  'climat': 'Climatización Piletas',\n  'climatizacion': 'Climatización Piletas',\n  'acs': 'ACS',\n  'agua caliente': 'ACS',\n  'biomasa': 'Biomasa',\n  'calefaccion': 'Calefacción Eléctrica',\n  'calefacción': 'Calefacción Eléctrica',\n  'pre': 'Calefacción Eléctrica',\n  'piso radiante': 'Calefacción Eléctrica',\n  'luminaria': 'Luminaria Solar',\n  'consultoria': 'Varios',\n  'consultoría': 'Varios',\n  'monitoreo': 'Varios',\n  'gestoria': 'Varios',\n  'gestoría': 'Varios',\n  'varios': 'Varios'\n};\n\nfor (const label of labels) {\n  const labelName = (label.name || '').toLowerCase();\n  for (const [key, value] of Object.entries(mapeoCC)) {\n    if (labelName.includes(key)) {\n      ccSearchTerm = value;\n      break;\n    }\n  }\n  if (ccSearchTerm !== 'Varios') break;\n}\n\n// Extraer nombre del cliente - manejar nombres con guiones\nlet cardName = tarjeta.name || '';\n// Quitar guiones iniciales y espacios\ncardName = cardName.replace(/^[-\\s]+/, '');\n// Dividir por ' - ' para obtener cliente\nconst parts = cardName.split(' - ');\nlet nombreCliente = parts[0]?.trim() || cardName;\n\n// Si quedó vacío, usar el nombre completo\nif (!nombreCliente) {\n  nombreCliente = tarjeta.name || 'Sin Cliente';\n}\n\nreturn {\n  nombreTarjeta: tarjeta.name,\n  nombreCliente: nombreCliente,\n  email: email,\n  celular: celular,\n  monto: monto,\n  ccSearchTerm: ccSearchTerm\n};"
            },
