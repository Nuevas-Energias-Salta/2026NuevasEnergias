            "name": "Notion - Leer Solicitudes",
            "type": "n8n-nodes-base.notion",
            "position": [
                250,
                300
            ]
        },
        {
            "parameters": {
                "resource": "databasePage",
                "databaseId": "2e0c81c3-5804-815a-8755-f4f254257f6a",
                "returnAll": true,
                "filters": {
                    "conditions": [
                        {
                            "key": "Fecha Emisión",
                            "condition": "on_or_after",
                            "returnValue": "={{$json.properties['Fecha Inicio'].date.start}}"
                        },
                        {
                            "key": "Fecha Emisión",
                            "condition": "on_or_before",
                            "returnValue": "={{$json.properties['Fecha Fin'].date.start}}"
                        }
                    ]
                }
            },
            "name": "Notion - Obtener CxC Filtradas",
            "type": "n8n-nodes-base.notion",
            "position": [
                450,
                300
            ]
        },
        {
            "parameters": {
                "functionCode": "// Calcular totales\nlet totalMonto = 0;\nlet totalCobrado = 0;\n\nfor (const item of items) {\n  const monto = item.json.properties['Monto Base']?.number || item.json.properties['Monto']?.number || 0;\n  \n  const cobradoProp = item.json.properties['Monto Cobrado Base'] || item.json.properties['Monto Cobrado'];\n  let cobrado = 0;\n  \n  if (cobradoProp?.type === 'rollup') {\n    cobrado = cobradoProp.rollup?.number || 0;\n  } else {\n    cobrado = cobradoProp?.number || 0;\n  }\n  \n  totalMonto += monto;\n  totalCobrado += cobrado;\n}\n\nconst totalPendiente = totalMonto - totalCobrado;\n\n// Obtener fechas de la solicitud\nconst fechaInicio = items[0].json.properties['Fecha Inicio'].date.start;\nconst fechaFin = items[0].json.properties['Fecha Fin'].date.start;\nconst periodo = `Rango: ${fechaInicio} a ${fechaFin}`;\n\nreturn [{\n  json: {\n    periodo: periodo,\n    montoTotal: totalMonto,\n    montoCobrado: totalCobrado,\n    saldoPendiente: totalPendiente,\n    solicitudId: items[0].json.id\n  }\n}];"
            },
            "name": "Calcular Totales",
            "type": "n8n-nodes-base.function",
            "position": [
                650,
                300
            ]
        },
        {
            "parameters": {
                "resource": "databasePage",
                "operation": "getAll",
                "databaseId": "REEMPLAZAR_CON_ID_RESUMEN_CXC",
                "filters": {
                    "conditions": [
                        {
                            "key": "Período",
                            "condition": "equals",
                            "returnValue": "={{$json.periodo}}"
                        }
                    ]
                }
            },
            "name": "Buscar Fila Existente",
