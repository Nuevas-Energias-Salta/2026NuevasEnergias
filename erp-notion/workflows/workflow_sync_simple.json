        {
            "parameters": {
                "jsCode": "const tarjetas = $('Get Cards').all();\nconst proyectos = $('Get Projects').all();\n\n// Nombres existentes\nconst existentes = new Set();\nfor (const p of proyectos) {\n  try {\n    const nombre = p.json.properties?.Nombre?.title?.[0]?.text?.content;\n    if (nombre) existentes.add(nombre);\n  } catch {}\n}\n\n// Tarjetas nuevas\nconst nuevas = [];\nfor (const t of tarjetas) {\n  if (!existentes.has(t.json.name)) {\n    nuevas.push({ json: { name: t.json.name } });\n  }\n}\n\nif (nuevas.length === 0) {\n  return { json: { message: 'No hay tarjetas nuevas', count: 0 } };\n}\n\nreturn nuevas;"
            },
