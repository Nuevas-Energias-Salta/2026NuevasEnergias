                        },
                        {
                            "key": "Saldo Pendiente",
                            "numberValue": "={{ $json.saldoPendiente }}"
                        }
                    ]
                }
            },
            "id": "f6g7h8i9-j0k1-2345-fghi-jk6789012345",
