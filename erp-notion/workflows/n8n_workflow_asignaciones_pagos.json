                        }
                    ]
                },
                "options": {}
            },
            "id": "get-cxp-details",
            "name": "Get CxP Details",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                -200,
                200
            ]
        },
        {
            "parameters": {
                "jsCode": "// Recopilar todas las CxP y calcular asignaciones FIFO\nconst allCxP = $items('Get CxP Details');\nconst firstItem = $('Extract Pagos con CxP').item.json;\nlet montoRestante = firstItem.monto;\nconst asignaciones = [];\n\n// Ordenar por fecha (FIFO)\nconst cxpOrdenadas = allCxP.map(item => {\n  const props = item.json.properties || {};\n  return {\n    id: item.json.id,\n    concepto: props['Concepto']?.title?.[0]?.plain_text || 'Sin concepto',\n    montoBase: props['Monto base']?.number || props['Monto']?.number || 0,\n    montoPagado: props['Monto Pagado']?.rollup?.number || 0,\n    fechaFactura: props['Fecha Factura']?.date?.start || '2000-01-01'\n  };\n}).sort((a, b) => a.fechaFactura.localeCompare(b.fechaFactura));\n\n// Distribuir el pago (FIFO)\nfor (const cxp of cxpOrdenadas) {\n  if (montoRestante <= 0) break;\n  \n  const saldoPendiente = cxp.montoBase - cxp.montoPagado;\n  if (saldoPendiente <= 0) continue;\n  \n  const montoAsignar = Math.min(montoRestante, saldoPendiente);\n  \n  asignaciones.push({\n    cxpId: cxp.id,\n    cxpConcepto: cxp.concepto,\n    montoAsignado: montoAsignar,\n    pagoId: firstItem.pagoId,\n    fechaPago: firstItem.fechaPago,\n    // Determinar si queda completamente pagada\n    quedaPagada: (cxp.montoPagado + montoAsignar) >= cxp.montoBase\n  });\n  \n  montoRestante -= montoAsignar;\n}\n\nreturn asignaciones;"
            },
