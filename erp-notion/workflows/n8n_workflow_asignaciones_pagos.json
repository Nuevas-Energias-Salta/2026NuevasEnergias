                                "operation": "equals"
                            }
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
            "id": "if-needs-process",
            "name": "Needs Processing?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                -600,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "// Preparar datos para obtener info de cada CxP\nconst prevData = $('Extract Pagos con CxP').item.json;\nconst items = [];\n\nfor (const cxpId of prevData.cxpIds) {\n  items.push({\n    cxpId: cxpId,\n    pagoId: prevData.pagoId,\n    montoTotalPago: prevData.monto,\n    fechaPago: prevData.fechaPago,\n    conceptoPago: prevData.conceptoPago\n  });\n}\n\nreturn items;"
            },
            "id": "prep-cxp-fetch",
            "name": "Prep CxP Fetch",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                -400,
                200
            ]
        },
        {
            "parameters": {
                "method": "GET",
                "url": "=https://api.notion.com/v1/pages/{{ $json.cxpId }}",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Authorization",
                            "value": "Bearer YOUR_NOTION_TOKEN_HERE"
                        },
                        {
