            "id": "trigger-poll",
            "name": "Poll Registro de Pagos",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                -1200,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "// Filtrar pagos que tienen CxP vinculadas y necesitan procesarse\nconst pages = $input.item.json.results || [];\nconst pagosConCxP = [];\n\nfor (const page of pages) {\n  const props = page.properties || {};\n  const cxpRelation = props['Cuenta por Pagar']?.relation || [];\n  const monto = props['Monto']?.number || 0;\n  \n  // Solo procesar pagos que tienen CxP vinculadas y monto > 0\n  if (cxpRelation.length > 0 && monto > 0) {\n    pagosConCxP.push({\n      pagoId: page.id,\n      monto: monto,\n      cxpIds: cxpRelation.map(r => r.id),\n      fechaPago: props['Fecha Pago']?.date?.start || new Date().toISOString().split('T')[0],\n      concepto: props['Concepto']?.title?.[0]?.plain_text || 'Pago'\n    });\n  }\n}\n\nreturn pagosConCxP;"
            },
            "id": "extract-pagos",
            "name": "Extract Pagos con CxP",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                -1000,
                300
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "=https://api.notion.com/v1/databases/2eec81c3-5804-8198-837b-c13a979dd872/query",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Authorization",
                            "value": "Bearer YOUR_NOTION_TOKEN_HERE"
                        },
                        {
                            "name": "Notion-Version",
                            "value": "2022-06-28"
                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\"filter\":{\"property\":\"Pago\",\"relation\":{\"contains\":\"{{ $json.pagoId }}\"}}}",
                "options": {}
            },
            "id": "check-existing",
            "name": "Check Existing Asignaciones",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                -800,
                300
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict"
                    },
                    "conditions": [
                        {
                            "id": "no-existing",
                            "leftValue": "={{ $json.results.length }}",
                            "rightValue": 0,
                            "operator": {
