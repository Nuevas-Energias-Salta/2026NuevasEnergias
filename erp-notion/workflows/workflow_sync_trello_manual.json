            "id": "get-projects",
            "name": "Get Notion Projects",
            "type": "n8n-nodes-base.notion",
            "typeVersion": 2,
            "position": [
                650,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "// Obtener tarjetas de Trello y proyectos existentes\nconst tarjetas = $('Get Trello Cards').all();\nconst proyectos = $('Get Notion Projects').all();\n\n// Nombres de proyectos existentes\nconst existentes = new Set();\nfor (const p of proyectos) {\n  try {\n    const nombre = p.json.properties?.Nombre?.title?.[0]?.text?.content;\n    if (nombre) existentes.add(nombre);\n  } catch {}\n}\n\n// Filtrar tarjetas nuevas\nconst nuevas = [];\nfor (const t of tarjetas) {\n  if (!existentes.has(t.json.name)) {\n    nuevas.push({\n      json: {\n        name: t.json.name,\n        nombreCliente: t.json.name.split('-')[0].trim(),\n        customFieldItems: t.json.customFieldItems || []\n      }\n    });\n  }\n}\n\nreturn nuevas;"
            },
            "id": "filter-new",
            "name": "Filter New Cards",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                850,
                300
            ]
        },
        {
            "parameters": {
                "resource": "databasePage",
                "operation": "getAll",
                "databaseId": "2e0c81c3-5804-8199-8d24-ded823eae751",
                "returnAll": false,
                "limit": 1,
                "filterType": "manual",
                "matchType": "allFilters",
                "filters": {
                    "conditions": [
                        {
                            "key": "Nombre",
                            "condition": "equals",
                            "string": "={{ $json.nombreCliente }}"
                        }
                    ]
                }
            },
            "id": "find-client",
            "name": "Find Client",
            "type": "n8n-nodes-base.notion",
            "typeVersion": 2,
            "position": [
                1050,
                300
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict"
                    },
                    "conditions": [
                        {
                            "id": "client-exists",
                            "leftValue": "={{ $json.id }}",
                            "rightValue": "",
                            "operator": {
                                "type": "string",
                                "operation": "exists"
                            }
                        }
                    ],
                    "combinator": "and"
                }
            },
