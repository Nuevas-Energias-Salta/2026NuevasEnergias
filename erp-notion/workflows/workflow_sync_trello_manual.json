                "jsCode": "// Contar cuántos proyectos se crearon\nconst creados = $input.all().length;\n\nreturn {\n  success: true,\n  message: `Sincronización completada. ${creados} proyectos nuevos creados.`,\n  creados: creados\n};"
            },
